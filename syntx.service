[Unit]
Description=Autopasting Syntx Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Autopasting-Syntx
ExecStart=/root/Autopasting-Syntx/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
